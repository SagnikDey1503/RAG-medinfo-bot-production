# ------------------------------------------------------------------
# Copy this file to `.env` and fill in your keys.
#   cp .env.example .env
# ------------------------------------------------------------------

# REQUIRED — your OpenAI API key
OPENAI_API_KEY=sk-...

# OPTIONAL — enables the CRAG web-search fallback. Get one at tavily.com.
# TAVILY_API_KEY=tvly-...

# ---- Models (cost-optimized defaults) ----
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---- Feature toggles (all on by default). Set to false to disable. ----
# ENABLE_QUERY_REWRITE=true
# ENABLE_MULTI_QUERY=true
# ENABLE_HYDE=true
# ENABLE_ROUTER=true
# ENABLE_DECOMPOSITION=true
# ENABLE_RERANK=true
# ENABLE_RETRIEVAL_VERIFIER=true
# ENABLE_ANSWER_VERIFIER=true
# ENABLE_COMPRESSION=true
# ENABLE_WEB_FALLBACK=true

# ---- Tuning ----
# MAX_HEAL_ATTEMPTS=3
# RETRIEVAL_PASS_THRESHOLD=0.6
# FINAL_K=6
# MULTI_QUERY_COUNT=4

# ---- CORS: allowed frontend origins (comma separated) ----
CORS_ORIGINS=http://localhost:3000
